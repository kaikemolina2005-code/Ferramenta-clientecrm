# ADVGD CRM - Production Environment Configuration
# ════════════════════════════════════════════════════════════

# ═══ Node Environment
NODE_ENV=production
PORT=3000

# ═══ Database Configuration
DB_USER=advocacia_user
DB_PASSWORD=mude_esta_senha_em_producao_123!@#
DB_NAME=advocacia_crm
DATABASE_URL=postgresql://advocacia_user:mude_esta_senha_em_producao_123!@#@postgres:5432/advocacia_crm

# ═══ JWT & Security
JWT_SECRET=mude_esta_chave_secreta_muito_longa_e_segura_em_producao_xyz789!@#$%^&*()

# ═══ URLs
FRONTEND_URL=https://seu-dominio.com
BACKEND_URL=https://api.seu-dominio.com

# ═══ Vite Configuration
VITE_API_URL=https://api.seu-dominio.com

# ═══ OpenAI (Opcional - para IA features)
OPENAI_API_KEY=sk-sua-chave-aqui

# ═══ SendGrid (Opcional - para Email)
SENDGRID_API_KEY=sua-chave-sendgrid-aqui
SENDGRID_FROM_EMAIL=noreply@seu-dominio.com

# ═══ WhatsApp Business API (Meta)
WHATSAPP_WEBHOOK_TOKEN=seu_webhook_token_super_seguro_aqui
WHATSAPP_BUSINESS_PHONE_ID=seu_phone_number_id
WHATSAPP_BUSINESS_ACCESS_TOKEN=seu_access_token_eaa
WHATSAPP_BUSINESS_ACCOUNT_ID=seu_account_id

# ═══ PgAdmin (Opcional - para desenvolvimento)
PGADMIN_EMAIL=admin@advocacia.com
PGADMIN_PASSWORD=mude_esta_senha_pgadmin

# ═══ Logging
LOG_LEVEL=info

# ═══ Email Service (Escolher um)
EMAIL_SERVICE=sendgrid  # ou: smtp, mock

# ═══ SMTP Configuration (se usar SMTP)
SMTP_HOST=smtp.seu-provider.com
SMTP_PORT=587
SMTP_USER=seu-email@seu-dominio.com
SMTP_PASS=sua-senha-smtp

# ═══ Socket.io Configuration
SOCKET_CORS_ORIGIN=https://seu-dominio.com

# ═══ Redis (Opcional - para caching)
REDIS_URL=redis://redis:6379

# ═══ Monitoring (Opcional)
SENTRY_DSN=sua-chave-sentry-aqui

# ═══ Rate Limiting
RATE_LIMIT_WINDOW_MS=900000  # 15 minutos
RATE_LIMIT_MAX_REQUESTS=100

