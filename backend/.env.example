# Database
DATABASE_URL="postgresql://user:password@localhost:5432/advocacia_crm"

# JWT
JWT_SECRET="your-secret-key-here"
JWT_EXPIRES_IN="7d"

# Groq
GROQ_API_KEY="..."

# Typebot (chatbot - token secreto para proteger os endpoints de webhook)
TYPEBOT_WEBHOOK_SECRET="token-secreto-typebot-aqui"

# OneDrive (backup de documentos - opcional, requer Microsoft 365 empresarial)
ONEDRIVE_CLIENT_ID="your-azure-app-client-id"
ONEDRIVE_CLIENT_SECRET="your-azure-app-client-secret"
ONEDRIVE_TENANT_ID="your-azure-tenant-id"
ONEDRIVE_USER_EMAIL="documentos@seudominio.com"
ONEDRIVE_FOLDER_NAME="CRM Documentos"

# WhatsApp Business
WHATSAPP_BUSINESS_PHONE_ID="your-phone-id"
WHATSAPP_BUSINESS_ACCESS_TOKEN="your-access-token"
WHATSAPP_BUSINESS_WEBHOOK_TOKEN="your-webhook-token"

# Server
PORT=3000
NODE_ENV=development
FRONTEND_URL="http://localhost:5173"

# Socket.io
SOCKET_IO_PORT=3001
